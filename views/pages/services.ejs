          // Reset upload button
          uploadButtonText.textContent = "Upload CSV";
          uploadButtonIcon.className = "fas fa-cloud-upload-alt";
          uploadButton.classList.remove('uploading');
        }
      });

      // Function to initiate download
      async function initiateDownload(btn, event) {
        // If called from HTML onclick, prevent default action
        if (event) {
          event.preventDefault();
        }
        
        const token = btn.dataset.token;
        const filename = btn.dataset.filename;
        const filepath = btn.dataset.filepath;
        
        if (!token && !filename) {
          console.error("Missing download information");
          showToast("Error: Missing download information", "error");
          return;
        }
        
        console.log(`Initiating download for token: ${token}, filename: ${filename}, filepath: ${filepath}`);
        
        // Add loading state to button
        btn.disabled = true;
        const originalText = btn.innerHTML;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Downloading...';
        
        try {
          let downloadUrl;
          
          // If we have a direct filepath, use it for better reliability
          if (filepath) {
            // Use direct download for better reliability
            downloadUrl = `/direct-download/${encodeURIComponent(filename)}`;
            console.log(`Using direct download with filename: ${filename}`);
          } else {
            // Fall back to token-based download
            downloadUrl = `/download/${encodeURIComponent(token)}`;
            console.log(`Using token-based download: ${token}`);
          }
          
          // Create a download link
          const a = document.createElement('a');
          a.style.display = 'none';
          a.href = downloadUrl;
          a.target = '_blank'; // Open in new tab so the download happens in background
          document.body.appendChild(a);
          
          // Trigger the download
          console.log(`Initiating download from: ${downloadUrl}`);
          a.click();
          
          // Remove anchor after clicking
          setTimeout(() => {
            document.body.removeChild(a);
            // Reset button state
            btn.disabled = false;
            btn.innerHTML = originalText;
          }, 1000);
        } catch (error) {
          console.error('Download error:', error);
          showToast('Error downloading file. Please try again.', 'error');
          btn.disabled = false;
          btn.innerHTML = originalText;
        }
      }

      // Tab switching functionality
      const tabButtons = document.querySelectorAll('.tab-btn');
      const historyTables = document.querySelectorAll('.history-table');
      
      tabButtons.forEach(btn => {
        btn.addEventListener('click', () => {
          // Remove active class from all buttons and tables
          tabButtons.forEach(b => b.classList.remove('active'));
          historyTables.forEach(t => t.classList.remove('active'));
          
          // Add active class to clicked button and corresponding table
          btn.classList.add('active');
          const tabId = btn.dataset.tab;
          document.getElementById(tabId).classList.add('active');
        });
      });

      // Load file history on page load
      loadFileHistory();
    });

