            { label: 'Moov', data: data.chart3.moov, borderColor: 'rgba(0, 166, 251, 1)', backgroundColor: 'rgba(0, 166, 251, 0.2)', borderWidth: 2, pointBackgroundColor: 'rgba(0, 166, 251, 1)' }
