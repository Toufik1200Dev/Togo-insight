    // Function to render file history (globally defined)
    function renderFileHistory(fileGroups) {
      const allFilesTable = document.getElementById('all-files-table');
      const lillybelleFilesTable = document.getElementById('lillybelle-files-table');
      const arcepFilesTable = document.getElementById('arcep-files-table');
      
      if (!allFilesTable || !lillybelleFilesTable || !arcepFilesTable) {
        console.error('File history tables not found');
        return;
      }
      
      // Clear tables
      allFilesTable.innerHTML = '';
      lillybelleFilesTable.innerHTML = '';
      arcepFilesTable.innerHTML = '';
      
      // Show/hide no files messages
      document.querySelectorAll('.no-files-message').forEach(msg => {
        msg.classList.add('hidden');
      });
      
      if (fileGroups.length === 0) {
        document.querySelectorAll('.no-files-message').forEach(msg => {
          msg.classList.remove('hidden');
        });
        return;
      }
      
      // Helper to check Azure file existence
      async function verifyAzureFile(fileName, buttonElement) {
        try {
          // First check if the file has a reference
          const reference = getFileReference(fileName);
          
          if (reference) {
            // Check files by reference - this is more reliable than direct file check
            const response = await fetch(`/find-files-by-reference/${reference}`);
            const data = await response.json();
            
            if (response.ok && data.success) {
              console.log(`Checking reference ${reference} for ${fileName}`);
              
              // Look for a match for this filename (case insensitive)
              const foundFile = data.azureFiles.find(file => 
                file.name.toLowerCase().includes(fileName.toLowerCase()) ||
                (file.name.toLowerCase().includes('lillybelle') && fileName.toLowerCase().includes('lillybelle')) ||
                (file.name.toLowerCase().includes('arcep') && fileName.toLowerCase().includes('arcep'))
              );
              
              const fileExists = foundFile !== undefined;
              console.log(`Verified file ${fileName} exists in Azure by reference: ${fileExists}`);
              
              if (fileExists && buttonElement) {
                buttonElement.disabled = false;
                buttonElement.title = "File ready for download";
                buttonElement.classList.add('file-ready');
                
                // Store the verified file path in the button's data attribute
                buttonElement.dataset.filepath = foundFile.path;
              } else if (buttonElement) {
                buttonElement.disabled = true;
                buttonElement.title = "File not yet available in Azure storage";
                buttonElement.classList.add('file-pending');
              }
              
              return fileExists;
            }
          }
          
          // Fallback to direct file check
          const checkResponse = await fetch(`/direct-blob-check/${encodeURIComponent(fileName)}`);
          
          if (checkResponse.ok) {
            const checkData = await checkResponse.json();
            const fileExists = checkData.success;
            
            if (fileExists && buttonElement) {
              buttonElement.disabled = false;
              buttonElement.title = "File ready for download";
              buttonElement.classList.add('file-ready');
              
              // Store the filepath in the button
              buttonElement.dataset.filepath = checkData.filePath;
            } else if (buttonElement) {
              buttonElement.disabled = true;
              buttonElement.title = "File not yet available in Azure storage";
              buttonElement.classList.add('file-pending');
            }
            
            return fileExists;
          }
          
          return false;
        } catch (error) {
          console.error(`Error verifying file ${fileName}:`, error);
          return false;
        }
      }
      
      // Helper to extract reference from a filename
      function getFileReference(fileName) {
        // Try to extract reference from patterns like:
        // lillybelle_output_123456.xlsx or ARCEP_output_123456.xlsx
        const referenceMatch = fileName.match(/_output_(\d+)/i);
        if (referenceMatch && referenceMatch[1]) {
          return referenceMatch[1];
        }
        
        // Try to match just a numeric portion if no specific pattern
        const numericMatch = fileName.match(/\d+/);
        if (numericMatch) {
          return numericMatch[0];
        }
        
        return null;
      }
      
      // Populate tables
      fileGroups.forEach(group => {
        // Sort files by type
        const originalFile = group.files.find(f => f.fileType === 'original');
        const lillybelleFile = group.files.find(f => f.fileType === 'lillybelle');
        const arcepFile = group.files.find(f => f.fileType === 'arcep');
        
        const uploadDate = new Date(group.uploadedAt).toLocaleString();
        
        // All Files Table Row
        const allFilesRow = document.createElement('tr');
        allFilesRow.innerHTML = `
          <td>${group.reference}</td>
          <td>${group.originalName}</td>
          <td>${lillybelleFile ? 
            `<span class="file-name">${lillybelleFile.fileName}</span>` : 
            '<span class="processing-badge"><i class="fas fa-hourglass-half fa-spin"></i> Waiting for Snowflake...</span>'}</td>
          <td>${arcepFile ? 
            `<span class="file-name">${arcepFile.fileName}</span>` : 
            '<span class="processing-badge"><i class="fas fa-hourglass-half fa-spin"></i> Waiting for Snowflake...</span>'}</td>
          <td>${uploadDate}</td>
          <td class="action-cell">
            ${lillybelleFile ? `<button class="download-btn" data-token="${lillybelleFile.fileToken}" data-filename="${lillybelleFile.fileName}" data-reference="${group.reference}" title="Download Lillybelle File"><i class="fas fa-download"></i> Lillybelle</button>` : ''}
            ${arcepFile ? `<button class="download-btn" data-token="${arcepFile.fileToken}" data-filename="${arcepFile.fileName}" data-reference="${group.reference}" title="Download ARCEP File"><i class="fas fa-download"></i> ARCEP</button>` : ''}
            <button class="refresh-btn" data-reference="${group.reference}" title="Check for files"><i class="fas fa-sync-alt"></i></button>
            ${lillybelleFile ? `<button class="delete-btn" onclick="deleteFile('${lillybelleFile.id}')" title="Delete File"><i class="fas fa-trash"></i></button>` : ''}
            ${arcepFile ? `<button class="delete-btn" onclick="deleteFile('${arcepFile.id}')" title="Delete File"><i class="fas fa-trash"></i></button>` : ''}
          </td>
        `;
        allFilesTable.appendChild(allFilesRow);
        
        // Only add to Lillybelle table if Lillybelle file exists
        if (lillybelleFile) {
          const lillybelleRow = document.createElement('tr');
          lillybelleRow.innerHTML = `
            <td>${group.reference}</td>
            <td>${group.originalName}</td>
            <td>${lillybelleFile.fileName}</td>
            <td>${uploadDate}</td>
            <td class="action-cell">
              <button class="download-btn" data-token="${lillybelleFile.fileToken}" data-filename="${lillybelleFile.fileName}" data-reference="${group.reference}" title="Download Lillybelle File"><i class="fas fa-download"></i> Download</button>
              <button class="refresh-btn" data-reference="${group.reference}" title="Check for files"><i class="fas fa-sync-alt"></i></button>
              <button class="delete-btn" onclick="deleteFile('${lillybelleFile.id}')" title="Delete File"><i class="fas fa-trash"></i></button>
            </td>
          `;
          lillybelleFilesTable.appendChild(lillybelleRow);
        }
        
        // Only add to ARCEP table if ARCEP file exists
        if (arcepFile) {
          const arcepRow = document.createElement('tr');
          arcepRow.innerHTML = `
            <td>${group.reference}</td>
            <td>${group.originalName}</td>
            <td>${arcepFile.fileName}</td>
            <td>${uploadDate}</td>
            <td class="action-cell">
              <button class="download-btn" data-token="${arcepFile.fileToken}" data-filename="${arcepFile.fileName}" data-reference="${group.reference}" title="Download ARCEP File"><i class="fas fa-download"></i> Download</button>
              <button class="refresh-btn" data-reference="${group.reference}" title="Check for files"><i class="fas fa-sync-alt"></i></button>
              <button class="delete-btn" onclick="deleteFile('${arcepFile.id}')" title="Delete File"><i class="fas fa-trash"></i></button>
            </td>
          `;
          arcepFilesTable.appendChild(arcepRow);
        }
      });
      
      // Populate Analysis tab: Lillybelle file selector (card-style with date/time)
      function formatReferenceDateTime(ref) {
        if (!ref || ref.length < 12) return '';
        const d = ref.slice(6, 8), m = ref.slice(4, 6), y = ref.slice(0, 4), h = ref.slice(8, 10), min = ref.slice(10, 12);
        const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
        const mi = parseInt(m, 10) - 1;
        return (mi >= 0 && mi < 12) ? `${parseInt(d, 10)} ${months[mi]} ${y}, ${h}:${min}` : ref;
      }
      const analysisButtonsContainer = document.getElementById('analysis-lillybelle-buttons');
      if (analysisButtonsContainer) {
        const lillybelleList = fileGroups.filter(g => g.files.some(f => f.fileType === 'lillybelle')).map(g => {
          const lb = g.files.find(f => f.fileType === 'lillybelle');
          return { reference: g.reference, fileName: lb.fileName, uploadedAt: g.uploadedAt };
        });
        if (lillybelleList.length === 0) {
          analysisButtonsContainer.innerHTML = '<span id="analysis-no-files-hint" class="analysis-no-files-hint">No Lillybelle files in history. Upload and process a file first.</span>';
        } else {
          analysisButtonsContainer.innerHTML = '';
          lillybelleList.forEach(({ reference, fileName, uploadedAt }) => {
            const card = document.createElement('button');
            card.type = 'button';
            card.className = 'analysis-file-card';
            card.dataset.reference = reference;
            card.dataset.filename = fileName;
            card.title = 'Use this file to generate charts';
            const dateTimeStr = formatReferenceDateTime(reference) || (uploadedAt ? new Date(uploadedAt).toLocaleString() : '');
            card.innerHTML = `
              <span class="analysis-file-card-icon"><i class="fas fa-file-excel"></i></span>
              <span class="analysis-file-card-body">
                <span class="analysis-file-card-name">${fileName}</span>
                <span class="analysis-file-card-date">${dateTimeStr}</span>
              </span>
              <span class="analysis-file-card-arrow"><i class="fas fa-chevron-right"></i></span>
            `;
            card.addEventListener('click', function() { loadChartsForFile(this.dataset.reference, this.dataset.filename); });
            analysisButtonsContainer.appendChild(card);
          });
        }
      }
      
      // After rendering all tables, verify file existence for each download button and attach event listeners
      document.querySelectorAll('.download-btn').forEach(async (btn) => {
        const fileName = btn.dataset.filename;
        if (fileName) {
          await verifyAzureFile(fileName, btn);
          
          // Add direct event listener for downloads
          btn.addEventListener('click', function(e) {
            e.preventDefault();
            const token = this.dataset.token;
            if (token) {
              downloadFile(token);
            }
          });
        }
      });
      
      // Add event listeners to refresh buttons
      document.querySelectorAll('.refresh-btn').forEach((btn) => {
        const reference = btn.dataset.reference;
        if (reference) {
          btn.addEventListener('click', function(e) {
            e.preventDefault();
            checkFiles(reference);
          });
        }
      });
    }

    // Function to check files for a specific reference
    async function checkFilesForReference(reference) {
      // Show toast notification
      showToast(`Checking for files with reference: ${reference}...`, 'info');
      
      try {
        // Call the API to check for files by reference
        const response = await fetch(`/find-files-by-reference/${reference}`);
        const data = await response.json();
        
        if (response.ok && data.success) {
          const filesFound = data.azureFiles.length > 0;
          
          if (filesFound) {
            showToast(`Found ${data.azureFiles.length} file(s) for reference ${reference}`, 'success');
            
            // Reload the file history to update status
            loadFileHistory();
            return true;
          } else {
            showToast(`No files found for reference ${reference} yet`, 'info');
            return false;
          }
        } else {
          showToast('Error checking files. Please try again.', 'error');
          return false;
        }
      } catch (error) {
        console.error('Error checking files:', error);
        showToast('Error checking files. Please try again.', 'error');
        return false;
      }
    }

    // Define placeholder dashboard functions if they don't exist elsewhere
    function initDashboardCharts() {
      console.log("Dashboard charts initialized");
      // Implementation would go here
    }
    
    function setupDashboardFilters() {
      console.log("Dashboard filters setup complete");
      // Implementation would go here
    }
    
    // Initialize dashboard components after the page loads
    document.addEventListener('DOMContentLoaded', () => {
      // Initialize Dashboard Charts
      initDashboardCharts();
      setupDashboardFilters();
    });

    // Simple direct download function for history table buttons
    function downloadFile(token) {
      if (!token) return;
      window.location.href = `/download/${encodeURIComponent(token)}`;
    }
    
    // Direct helper function to check for files by reference
    function checkFiles(reference) {
      if (!reference) return;
      
      // Add animation to the refresh button
      const btn = document.querySelector(`.refresh-btn[data-reference="${reference}"]`);
      if (btn) {
        const icon = btn.querySelector('i');
        if (icon) {
          btn.classList.add('refreshing');
          icon.className = 'fas fa-sync-alt fa-spin';
        }
      }
      
      fetch(`/find-files-by-reference/${reference}`)
        .then(response => response.json())
        .then(data => {
          if (data.success) {
            showToast(`Found ${data.azureFiles.length} file(s) for reference ${reference}`, 'success');
            loadFileHistory();
          } else {
            showToast(`No files found for reference ${reference}`, 'info');
          }
        })
        .catch(error => {
          console.error('Error checking files:', error);
          showToast('Error checking files', 'error');
        })
        .finally(() => {
          // Remove animation from the refresh button
          if (btn) {
            const icon = btn.querySelector('i');
            if (icon) {
              btn.classList.remove('refreshing');
              icon.className = 'fas fa-sync-alt';
            }
          }
        });
    }

    // Function to delete file
    async function deleteFile(fileId) {
      if (!confirm('Are you sure you want to delete this file?')) {
        return;
      }
      
      try {
        const response = await fetch(`/delete-file/${fileId}`, {
          method: 'DELETE'
        });
        
        const data = await response.json();
        
        if (response.ok && data.success) {
          showToast('File deleted successfully', 'success');
          // Reload file history
          loadFileHistory();
        } else {
          showToast(data.message || 'Error deleting file', 'error');
        }
      } catch (error) {
        console.error('Error deleting file:', error);
        showToast('Error deleting file', 'error');
      }
    }
  </script>

