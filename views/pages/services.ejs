<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Services - Togo Insight</title>
  <!-- Font Awesome -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <!-- Google Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;500;700&family=Poppins:wght@300;400;500;700&display=swap" rel="stylesheet">
  <!-- AOS Animation Library -->
  <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
  <link rel="icon" type="image/x-icon" href="/imgs/logo-togo.png">
  <link rel="stylesheet" href="/styles/services.css">
</head>
<body>
  <!-- Particles Background -->
  <div id="particles-js"></div>
  
  <!-- Floating Tech Elements -->
  <div class="floating-tech">
    <div class="tech-element" style="--delay: 0s; --size: 60px; --top: 15%; --left: 5%;">
      <i class="fas fa-satellite"></i>
    </div>
    <div class="tech-element" style="--delay: 3s; --size: 70px; --top: 70%; --left: 80%;">
      <i class="fas fa-network-wired"></i>
    </div>
    <div class="tech-element" style="--delay: 6s; --size: 50px; --top: 40%; --left: 90%;">
      <i class="fas fa-broadcast-tower"></i>
    </div>
    <div class="tech-element" style="--delay: 9s; --size: 65px; --top: 80%; --left: 30%;">
      <i class="fas fa-microchip"></i>
    </div>
    <div class="tech-element" style="--delay: 12s; --size: 55px; --top: 25%; --left: 70%;">
      <i class="fas fa-wifi"></i>
    </div>
  </div>

  <header class="navbar">
    <div class="logo" onclick="window.location.href='/'" style="cursor:pointer;">
      <img src="/imgs/logo-togo.png">
      <img id="lillybellelogo" src="/imgs/logos/logolilly.png">
    </div>
    <nav>
      <a href="/">Home</a> 
      <a href="/services" class="active">Services</a>
      <a href="/about">About</a>
      <a href="/contact">Contact</a>
    </nav>
    <% if (typeof user !== 'undefined' && user) { %>
      <div class="navbar-user">
        <h2>Hello <%= user.firstName %>!</h2>
        <form action="/logout" method="POST" style="display:inline;">
          <button type="submit" class="contact-button">Logout</button>
        </form>
      </div>
    <% } else { %>
      <div class="contact" id="auth-buttons">
        <a href="/signup" class="contact-button">Signup</a>
        <a href="/login" class="contact-button">Login</a>
      </div>
    <% } %>
  </header>

  <main class="container">
    <div class="service-tabs">
      <button type="button" class="service-tab-btn active" data-section="calculations">Calculations</button>
      <button type="button" class="service-tab-btn" data-section="history">History</button>
      <button type="button" class="service-tab-btn" data-section="analysis">Analysis</button>
    </div>

    <div id="section-calculations" class="service-section active">
    <div class="service-intro" data-aos="fade-up">
      <div class="tech-badge"><i class="fas fa-cogs"></i> Data Processing</div>
      <h1>CSV <span class="highlight">Processing</span> Service</h1>
      <p>Please upload your CSV file while keeping the following naming format to ensure proper data processing:
        RawData_ExportToCsv_YYYYMMDDHHMMSS.csv</p>
    </div>

    <div class="upload-section" data-aos="fade-up" data-aos-delay="200">
      <div class="upload-container">
        <form id="uploadForm" enctype="multipart/form-data">
          <label for="fileInput" class="upload-btn" id="uploadButton">
            <i class="fas fa-cloud-upload-alt"></i>
            <span>Upload CSV</span>
          </label>
          <input type="file" id="fileInput" accept=".csv" hidden>
        </form>
      </div>

      <div class="processing-container">
        <div class="processing-status hidden">
          <div class="processing-step">
            <div class="step-label">Original File</div>
            <div class="step-icon"><i class="fas fa-file-csv"></i></div>
            <div class="step-status">Uploaded to Snowflake</div>
          </div>
          
          <div class="processing-arrow">
            <i class="fas fa-arrow-right"></i>
          </div>
          
          <div class="processing-step" id="lillybelle-processing">
            <div class="step-label">Lillybelle Output</div>
            <div class="step-icon"><i class="fas fa-hourglass-half fa-spin"></i></div>
            <div class="step-status">Waiting for Snowflake...</div>
          </div>
          
          <div class="processing-arrow">
            <i class="fas fa-arrow-right"></i>
          </div>
          
          <div class="processing-step" id="arcep-processing">
            <div class="step-label">ARCEP Output</div>
            <div class="step-icon"><i class="fas fa-hourglass-half fa-spin"></i></div>
            <div class="step-status">Waiting for Snowflake...</div>
          </div>
        </div>
        
        <div class="loading-spinner hidden">
          <i class="fas fa-sync-alt fa-spin"></i>
          <span>Uploading...</span>
        </div>
      </div>

      <div class="download-container">
        <div class="download-buttons hidden">
          <button id="downloadLillybelleBtn" class="download-btn" disabled>
          <i class="fas fa-download"></i>
            Download Lillybelle Output
        </button>
          <button id="downloadArcepBtn" class="download-btn" disabled>
            <i class="fas fa-download"></i>
            Download ARCEP Output
          </button>
        </div>
        <span id="currentFileName" class="file-name"></span>
      </div>
    </div>

    <section class="services-workflow" data-aos="fade-up" data-aos-delay="300">
      <div class="workflow-header">
        <div class="tech-badge"><i class="fas fa-project-diagram"></i> Workflow</div>
        <h2>How Our <span class="highlight">Processing</span> Works</h2>
      </div>
      <div class="workflow-steps">
        <div class="workflow-step" data-aos="zoom-in" data-aos-delay="400">
          <div class="step-icon"><i class="fas fa-upload"></i></div>
          <h3>Upload</h3>
          <p>Upload your CSV file through our secure interface</p>
        </div>
        <div class="workflow-arrow"><i class="fas fa-chevron-right"></i></div>
        <div class="workflow-step" data-aos="zoom-in" data-aos-delay="600">
          <div class="step-icon"><i class="fas fa-cogs"></i></div>
          <h3>Process</h3>
          <p>Our algorithms analyze and optimize your data</p>
        </div>
        <div class="workflow-arrow"><i class="fas fa-chevron-right"></i></div>
        <div class="workflow-step" data-aos="zoom-in" data-aos-delay="800">
          <div class="step-icon"><i class="fas fa-download"></i></div>
          <h3>Download</h3>
          <p>Get your enhanced data ready for use</p>
        </div>
      </div>
    </section>
    </div>

    <div id="section-history" class="service-section">
    <section class="history-section" data-aos="fade-up" data-aos-delay="400">
      <div class="section-header">
        <div class="tech-badge"><i class="fas fa-history"></i> History</div>
        <h2>Upload and Download <span class="highlight">History</span></h2>
      </div>
      
      <!-- File History Tabs -->
      <div class="history-tabs">
        <button class="tab-btn active" data-tab="all-files">All Files</button>
        <button class="tab-btn" data-tab="lillybelle-files">Lillybelle Files</button>
        <button class="tab-btn" data-tab="arcep-files">ARCEP Files</button>
              </div>
      
      <!-- File History Tables -->
      <div class="history-tables">
        <!-- All Files Table (Active by default) -->
        <div class="history-table active" id="all-files">
          <table>
            <thead>
              <tr>
                <th>Reference</th>
                <th>Original File</th>
                <th>Lillybelle File</th>
                <th>ARCEP File</th>
                <th>Upload Date</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody id="all-files-table">
              <!-- This will be populated by JS -->
            </tbody>
          </table>
          <div class="no-files-message hidden">No files found</div>
              </div>
        
        <!-- Lillybelle Files Table -->
        <div class="history-table" id="lillybelle-files">
          <table>
            <thead>
              <tr>
                <th>Reference</th>
                <th>Original File</th>
                <th>Lillybelle File</th>
                <th>Upload Date</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody id="lillybelle-files-table">
              <!-- This will be populated by JS -->
            </tbody>
          </table>
          <div class="no-files-message hidden">No Lillybelle files found</div>
            </div>
        
        <!-- ARCEP Files Table -->
        <div class="history-table" id="arcep-files">
          <table>
            <thead>
              <tr>
                <th>Reference</th>
                <th>Original File</th>
                <th>ARCEP File</th>
                <th>Upload Date</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody id="arcep-files-table">
              <!-- This will be populated by JS -->
            </tbody>
          </table>
          <div class="no-files-message hidden">No ARCEP files found</div>
        </div>
      </div>
    </section>
    </div>

    <div id="section-analysis" class="service-section">
      <div class="section-header" data-aos="fade-up">
        <div class="tech-badge"><i class="fas fa-chart-line"></i> Analytics</div>
        <h2>Output <span class="highlight">Analysis</span></h2>
        <p>Select a Lillybelle file below to generate charts from its data.</p>
      </div>
      <div class="analysis-file-selector" data-aos="fade-up">
        <label class="analysis-file-label">Choose Lillybelle file:</label>
        <div id="analysis-lillybelle-buttons" class="analysis-lillybelle-buttons">
          <!-- Populated by JS from file history (Lillybelle files only) -->
          <span id="analysis-no-files-hint" class="analysis-no-files-hint">Load History or upload a file to see Lillybelle outputs here.</span>
        </div>
        <p id="analysis-selected-file" class="analysis-selected-file hidden"></p>
      </div>
      <div id="analysis-download-pdf-wrap" class="analysis-download-pdf-wrap hidden">
        <button type="button" id="analysis-download-pdf-btn" class="download-pdf-btn" title="Download all 4 charts as PDF with file name and date">
          <i class="fas fa-file-pdf"></i> Download charts as PDF
        </button>
      </div>
      <div class="analysis-charts">
        <div class="analysis-card" data-aos="fade-up">
          <h3>Distribution nombre de KPIs par résultat</h3>
          <canvas id="chartKpisResultat"></canvas>
        </div>
        <div class="analysis-card" data-aos="fade-up" data-aos-delay="100">
          <h3>Distribution % OK par localité et opérateur</h3>
          <canvas id="chartOkLocalite"></canvas>
        </div>
        <div class="analysis-card" data-aos="fade-up" data-aos-delay="200">
          <h3>Distribution % KPI OK par opérateur</h3>
          <canvas id="chartKpiRadar"></canvas>
        </div>
        <div class="analysis-card" data-aos="fade-up" data-aos-delay="300">
          <h3>Distribution % KPI OK par type de test</h3>
          <canvas id="chartKpiTypeTest"></canvas>
        </div>
      </div>
    </div>
  </main>

  <footer class="footer">
    <div class="footer-links">
      <a href="/">Home</a>
      <a href="/services">Services</a>
      <a href="/about">About</a>
      <a href="/contact">Contact</a>
    </div>
    <div class="footer-content">
      <a href="https://www.facebook.com/Lillybelle.Sarl/" target="_blank" class="footer-link" rel="noopener" aria-label="Facebook">
        <i class="fab fa-facebook-f footer-icon"></i>
        Facebook
      </a>
      <a href="https://www.linkedin.com/company/lillybelle/" target="_blank" class="footer-link" rel="noopener" aria-label="LinkedIn">
        <i class="fab fa-linkedin-in footer-icon"></i>
        LinkedIn
      </a>
      <a href="mailto:info@lillybelle.eu" class="footer-link">
        <i class="fas fa-envelope footer-icon"></i>
        info@lillybelle.eu
      </a>
      <a href="tel:+33608740517" class="footer-link">
        <i class="fas fa-phone footer-icon"></i>
        +(33) 6 08 74 05 17
      </a>
    </div>
    <p class="footer-tagline">Network analytics & telecom solutions</p>
    <p class="text-center text-muted">&copy; 2025 Togo Insight · Developed by Lillybelle</p>
  </footer>

  <!-- Scripts -->
  <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
  <script src="https://cdn.jsdelivr.net/particles.js/2.0.0/particles.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
  <script>
    // Service tabs: Calculations, History, Analysis
    document.querySelectorAll('.service-tab-btn').forEach(btn => {
      btn.addEventListener('click', function() {
        const sectionId = this.dataset.section;
        document.querySelectorAll('.service-tab-btn').forEach(b => b.classList.remove('active'));
        this.classList.add('active');
        document.querySelectorAll('.service-section').forEach(s => s.classList.remove('active'));
        const section = document.getElementById('section-' + sectionId);
        if (section) section.classList.add('active');
        if (sectionId === 'analysis') {
          if (typeof loadChartsForFile === 'function' && currentAnalysisReference) {
            loadChartsForFile(currentAnalysisReference, currentAnalysisFileName);
          } else if (typeof initAnalysisCharts === 'function' && analysisChartInstances && analysisChartInstances.length === 0) {
            initAnalysisCharts();
          }
        }
      });
    });

    // Initialize AOS animation library
    AOS.init({
      duration: 800,
      once: false,
      mirror: true
    });
    
    // Initialize particles.js
    particlesJS('particles-js', {
      particles: {
        number: {
          value: 100,
          density: { enable: true, value_area: 800 }
        },
        color: { value: ["#00a6fb", "#4cc9f0", "#0a2647"] },
        shape: {
          type: "circle",
          stroke: { width: 0, color: "#000000" },
          polygon: { nb_sides: 5 }
        },
        opacity: {
          value: 0.5,
          random: true,
          anim: { enable: true, speed: 1, opacity_min: 0.1, sync: false }
        },
        size: {
          value: 3,
          random: true,
          anim: { enable: true, speed: 2, size_min: 0.1, sync: false }
        },
        line_linked: {
          enable: true,
          distance: 150,
          color: "#4cc9f0",
          opacity: 0.4,
          width: 1
        },
        move: {
          enable: true,
          speed: 1,
          direction: "none",
          random: true,
          straight: false,
          out_mode: "out",
          bounce: false,
          attract: { enable: true, rotateX: 600, rotateY: 1200 }
        }
      },
      interactivity: {
        detect_on: "canvas",
        events: {
          onhover: { enable: true, mode: "grab" },
          onclick: { enable: true, mode: "push" },
          resize: true
        },
        modes: {
          grab: { distance: 140, line_linked: { opacity: 1 } },
          bubble: { distance: 400, size: 40, duration: 2, opacity: 8, speed: 3 },
          repulse: { distance: 200, duration: 0.4 },
          push: { particles_nb: 4 },
          remove: { particles_nb: 2 }
        }
      },
      retina_detect: true
    });

    // Global Toast notification function
    function showToast(message, type = 'info') {
      // Create toast element if it doesn't exist
      let toast = document.getElementById('toast-notification');
      if (!toast) {
        toast = document.createElement('div');
        toast.id = 'toast-notification';
        document.body.appendChild(toast);
      }
      
      // Set toast content and class
      toast.textContent = message;
      toast.className = `toast ${type}`;
      
      // Show the toast
      toast.classList.add('show');
      
      // Hide after 5 seconds
      setTimeout(() => {
        toast.classList.remove('show');
      }, 5000);
    }
    
    document.addEventListener('DOMContentLoaded', () => {
      const uploadForm = document.getElementById('uploadForm');
      const fileInput = document.getElementById('fileInput');
      const uploadButton = document.getElementById('uploadButton');
      const uploadButtonText = uploadButton.querySelector('span');
      const uploadButtonIcon = uploadButton.querySelector('i');
      const loadingSpinner = document.querySelector('.loading-spinner');
      const processingStatus = document.querySelector('.processing-status');
      const downloadButtons = document.querySelector('.download-buttons');
      const downloadLillybelleBtn = document.getElementById('downloadLillybelleBtn');
      const downloadArcepBtn = document.getElementById('downloadArcepBtn');
      const currentFileName = document.getElementById('currentFileName');
      
      let currentFileReference = '';
      let lillybelleFileToken = '';
      let arcepFileToken = '';
      
      // Initialize UI state
      function initUI() {
        loadingSpinner.classList.add('hidden');
        processingStatus.classList.add('hidden');
        downloadButtons.classList.add('hidden');
        downloadLillybelleBtn.disabled = true;
        downloadArcepBtn.disabled = true;
      }
      
      // Initialize UI on page load
      initUI();

      // Add click handler on the upload button for immediate visual feedback
      uploadButton.addEventListener('click', () => {
        // Show click animation
        uploadButton.classList.add('upload-btn-active');
        
        // Reset after animation
        setTimeout(() => {
          uploadButton.classList.remove('upload-btn-active');
        }, 300);
      });
      
      // Add direct event listeners to main download buttons
      if (downloadLillybelleBtn) {
        downloadLillybelleBtn.addEventListener('click', (e) => {
          e.preventDefault();
          initiateDownload(downloadLillybelleBtn, e);
        });
      }
      
      if (downloadArcepBtn) {
        downloadArcepBtn.addEventListener('click', (e) => {
          e.preventDefault();
          initiateDownload(downloadArcepBtn, e);
        });
      }

      // Reset the file input and update button state
      function resetUploadForm() {
        fileInput.value = '';
        uploadButton.classList.remove('uploading');
        uploadButtonText.textContent = "Upload CSV";
        uploadButtonIcon.className = "fas fa-cloud-upload-alt";
        
        // Clear status displays
        loadingSpinner.classList.add('hidden');
        processingStatus.classList.add('hidden');
        
        // Reset download buttons
        downloadButtons.classList.add('hidden');
        downloadLillybelleBtn.disabled = true;
        downloadArcepBtn.disabled = true;
        
        // Clear file tokens
        lillybelleFileToken = '';
        arcepFileToken = '';
        currentFileReference = '';
      }

      // Ensure both downloadLillybelleBtn and downloadArcepBtn have data-filename attributes
      function setDownloadButtonFile(btnElement, fileName, fileToken) {
        if (btnElement) {
          btnElement.dataset.filename = fileName;
          btnElement.dataset.token = fileToken;
        }
      }

      // Improve polling status updates
      function updateProcessingStatus(type, isReady, filePath = null) {
        // Handle UI updates for Lillybelle files
        if (type === 'lillybelle') {
          const lillybelleStep = document.getElementById('lillybelle-processing');
          
          if (isReady) {
            lillybelleStep.querySelector('.step-icon').innerHTML = '<i class="fas fa-check-circle" style="color: #4cc9f0;"></i>';
            lillybelleStep.querySelector('.step-status').textContent = 'Ready for Download';
            
            // Update button state if not already enabled
            if (downloadLillybelleBtn.disabled) {
              downloadLillybelleBtn.disabled = false;
              
              if (filePath) {
                downloadLillybelleBtn.dataset.filepath = filePath;
              }
              
              showToast('Lillybelle file is now available!', 'success');
            }
          } else {
            lillybelleStep.querySelector('.step-icon').innerHTML = '<i class="fas fa-hourglass-half fa-spin"></i>';
            lillybelleStep.querySelector('.step-status').textContent = 'Waiting for Snowflake...';
            downloadLillybelleBtn.disabled = true;
          }
        }
        // Handle UI updates for ARCEP files
        else if (type === 'arcep') {
          const arcepStep = document.getElementById('arcep-processing');
          
          if (isReady) {
            arcepStep.querySelector('.step-icon').innerHTML = '<i class="fas fa-check-circle" style="color: #4cc9f0;"></i>';
            arcepStep.querySelector('.step-status').textContent = 'Ready for Download';
            
            // Update button state if not already enabled
            if (downloadArcepBtn.disabled) {
              downloadArcepBtn.disabled = false;
              
              if (filePath) {
                downloadArcepBtn.dataset.filepath = filePath;
              }
              
              showToast('ARCEP file is now available!', 'success');
            }
          } else {
            arcepStep.querySelector('.step-icon').innerHTML = '<i class="fas fa-hourglass-half fa-spin"></i>';
            arcepStep.querySelector('.step-status').textContent = 'Waiting for Snowflake...';
            downloadArcepBtn.disabled = true;
          }
        }
      }
      
      // Function to handle polling for file processing
      function pollFileProcessing() {
        // Show processing status UI
        loadingSpinner.classList.add('hidden');
        processingStatus.classList.remove('hidden');
        downloadButtons.classList.remove('hidden');
        
        // Reset the processing status to waiting
        updateProcessingStatus('lillybelle', false);
        updateProcessingStatus('arcep', false);
        
        const intervalId = setInterval(async () => {
          try {
            // Try to directly find files in Azure by reference
            const filesResponse = await fetch(`/find-files-by-reference/${currentFileReference}`);
            const filesData = await filesResponse.json();
            
            if (filesResponse.ok && filesData.success) {
              console.log(`Found ${filesData.azureFiles.length} files matching reference ${currentFileReference} in Azure`);
              
              // Track if we found files of each type
              let foundLillybelle = false;
              let foundArcep = false;
              
              // Process each Azure file to see if it matches our expected files
              filesData.azureFiles.forEach(azureFile => {
                const fileName = azureFile.name.split('/').pop(); // Get just the filename part
                
                // Check if this is a Lillybelle file
                if (azureFile.name.toLowerCase().includes('lillybelle')) {
                  foundLillybelle = true;
                  
                  // Update Lillybelle file status
                  updateProcessingStatus('lillybelle', true, azureFile.path);
                  
                  // Set file info on download button
                  setDownloadButtonFile(downloadLillybelleBtn, fileName, lillybelleFileToken);
                } 
                // Check if this is an ARCEP file
                else if (azureFile.name.toLowerCase().includes('arcep')) {
                  foundArcep = true;
                  
                  // Update ARCEP file status
                  updateProcessingStatus('arcep', true, azureFile.path);
                  
                  // Set file info on download button
                  setDownloadButtonFile(downloadArcepBtn, fileName, arcepFileToken);
                }
              });
              
              // If both files are ready or we have at least one file after 2 minutes, stop polling
              const pollElapsedTime = Date.now() - pollStartTime;
              
              if ((foundLillybelle && foundArcep) || 
                  (filesData.azureFiles.length > 0 && pollElapsedTime > 120000)) {
                clearInterval(intervalId);
                showToast('All available Snowflake-processed files are ready!', 'success');
                
                // Also refresh the file history
                loadFileHistory();
              }
            } else {
              // Fallback to the check-processed-files endpoint
              const response = await fetch(`/check-processed-files/${currentFileReference}`);
              const data = await response.json();
              
              if (response.ok && data.success) {
                // Process each file result
                data.results.forEach(result => {
                  if (result.exists) {
                    // File exists in Azure OUTPUT folder
                    if (result.fileType === 'lillybelle') {
                      // Update Lillybelle file status
                      updateProcessingStatus('lillybelle', true, result.azurePath);
                      
                      // Set file info on download button
                      setDownloadButtonFile(downloadLillybelleBtn, result.fileName, result.fileToken);
                    } else if (result.fileType === 'arcep') {
                      // Update ARCEP file status
                      updateProcessingStatus('arcep', true, result.azurePath);
                      
                      // Set file info on download button
                      setDownloadButtonFile(downloadArcepBtn, result.fileName, result.fileToken);
                    }
                  }
                });
                
                // Check if both files are ready
                const allFilesReady = data.results.every(result => result.exists);
                if (allFilesReady) {
                  // Stop polling when all files are detected
                  clearInterval(intervalId);
                  
                  // Final success message
                  showToast('All Snowflake-processed files are now available!', 'success');
                  
                  // Refresh file history
                  loadFileHistory();
                }
              }
            }
          } catch (error) {
            console.error('Error polling for processed files:', error);
          }
        }, 5000); // Check every 5 seconds
        
        // Track when we started polling
        const pollStartTime = Date.now();
        
        // Stop polling after 10 minutes (600000 ms) no matter what
        setTimeout(() => {
          clearInterval(intervalId);
          
          // Final message if we stopped polling
          const lillybelleReady = !downloadLillybelleBtn.disabled;
          const arcepReady = !downloadArcepBtn.disabled;
          
          // Only show a message if no files were found
          if (!lillybelleReady && !arcepReady) {
            showToast('Stopped checking for processed files. Refresh to check again.', 'info');
          } else {
            showToast('Some files are ready for download. Stopped checking for more files.', 'info');
            
            // Refresh file history one more time
            loadFileHistory();
          }
        }, 600000);
      }

      // Function to check Azure storage directly
      async function listAzureFiles(container, prefix) {
        try {
          const response = await fetch(`/azure-files/${container}/${prefix || ''}`);
          if (response.ok) {
            const data = await response.json();
            console.log(`Files in ${container}${prefix ? '/' + prefix : ''}:`, data.files);
            return data.files;
          }
        } catch (error) {
          console.error('Error listing Azure files:', error);
          return [];
        }
