    let currentAnalysisFileName = '';
    let currentAnalysisReference = '';
    async function loadChartsForFile(reference, fileName) {
      if (!reference) return;
      const selEl = document.getElementById('analysis-selected-file');
      const pdfWrap = document.getElementById('analysis-download-pdf-wrap');
      document.querySelectorAll('.analysis-file-card').forEach(card => card.classList.remove('selected'));
      const clickedCard = document.querySelector('.analysis-file-card[data-reference="' + CSS.escape(String(reference)) + '"]');
      if (clickedCard) clickedCard.classList.add('selected');
      if (selEl) selEl.textContent = 'Loading charts…';
      if (selEl) selEl.classList.remove('hidden');
      if (pdfWrap) pdfWrap.classList.add('hidden');
      try {
        const response = await fetch('/api/lillybelle-chart-data/' + encodeURIComponent(reference));
        const json = await response.json();
        if (!response.ok) throw new Error(json.message || 'Failed to load chart data');
        initAnalysisCharts(json.chartData);
        currentAnalysisFileName = fileName || reference;
        currentAnalysisReference = reference;
        if (selEl) selEl.textContent = 'Charts from: ' + (fileName || reference);
        if (pdfWrap) pdfWrap.classList.remove('hidden');
        showToast('Charts updated from selected file', 'success');
      } catch (err) {
        if (selEl) selEl.textContent = 'Error loading file. Try again.';
        showToast(err.message || 'Error loading chart data', 'error');
      }
    }
    function downloadChartsPdf() {
      if (typeof jspdf === 'undefined') { showToast('PDF library not loaded', 'error'); return; }
      const ids = ['chartKpisResultat', 'chartOkLocalite', 'chartKpiRadar', 'chartKpiTypeTest'];
      const titles = [
        'Distribution nombre de KPIs par résultat',
        'Distribution % OK par localité et opérateur',
        'Distribution % KPI OK par opérateur',
        'Distribution % KPI OK par type de test'
      ];
      const canvases = ids.map(id => document.getElementById(id)).filter(Boolean);
      if (canvases.length === 0) { showToast('No charts to export', 'error'); return; }
      const now = new Date();
      const dateStr = now.getFullYear() + '-' + String(now.getMonth() + 1).padStart(2, '0') + '-' + String(now.getDate()).padStart(2, '0');
      const baseName = currentAnalysisFileName ? currentAnalysisFileName.replace(/\.[^/.]+$/, '') : 'charts';
      const pdfFileName = (baseName + '_charts_' + dateStr + '.pdf').replace(/\s+/g, '_');
      const sourceName = currentAnalysisFileName || currentAnalysisReference || 'Lillybelle output';

      // Render chart canvas at 2x resolution for crisp PDF
      function canvasToHighResImage(canvas, scale) {
        scale = scale || 2;
        const w = canvas.width;
        const h = canvas.height;
        const off = document.createElement('canvas');
        off.width = w * scale;
        off.height = h * scale;
        const ctx = off.getContext('2d');
        ctx.imageSmoothingEnabled = true;
        ctx.imageSmoothingQuality = 'high';
        ctx.drawImage(canvas, 0, 0, w, h, 0, 0, off.width, off.height);
        return off.toDataURL('image/png');
      }

      const { jsPDF } = jspdf;
      const doc = new jsPDF('p', 'mm', 'a4');
      const pageW = doc.internal.pageSize.getWidth();
      const pageH = doc.internal.pageSize.getHeight();
      const margin = 18;
      const contentW = pageW - 2 * margin;
      const maxImgH = pageH - 2 * margin - 28;
      const headerY = 12;
      const titleY = 20;
      const chartPadding = 4;
      const borderGray = 200;

      for (let i = 0; i < canvases.length; i++) {
        if (i > 0) doc.addPage();
        const c = canvases[i];
        const cw = Math.max(c.width || 400, 1);
        const ch = Math.max(c.height || 220, 1);
        const aspect = ch / cw;
        let imgW = contentW - 2 * chartPadding;
        let imgH = imgW * aspect;
        if (imgH > maxImgH) {
          imgH = maxImgH;
          imgW = imgH / aspect;
        }
        const imgX = margin + chartPadding + (contentW - 2 * chartPadding - imgW) / 2;
        const imgY = titleY + 6;

        doc.setFillColor(10, 38, 71);
        doc.rect(0, 0, pageW, 18, 'F');
        doc.setTextColor(230, 241, 255);
        doc.setFontSize(14);
        doc.setFont('helvetica', 'bold');
        doc.text('Togo Insight \u00B7 Analysis Report', margin, headerY);
        doc.setFont('helvetica', 'normal');
        doc.setFontSize(9);
        doc.text(sourceName + ' \u2014 ' + dateStr, margin, 17);
        doc.setTextColor(0, 0, 0);
        doc.setFontSize(11);
        doc.setFont('helvetica', 'bold');
        doc.setTextColor(20, 66, 114);
        doc.text(titles[i] || ('Chart ' + (i + 1)), margin, titleY + 4);
        doc.setFont('helvetica', 'normal');
        doc.setTextColor(0, 0, 0);
        doc.setDrawColor(borderGray);
        doc.setLineWidth(0.3);
        doc.setFillColor(255, 255, 255);
        doc.rect(imgX - chartPadding, imgY - chartPadding, imgW + 2 * chartPadding, imgH + 2 * chartPadding, 'F');
        doc.rect(imgX - chartPadding, imgY - chartPadding, imgW + 2 * chartPadding, imgH + 2 * chartPadding);
        const imgData = canvasToHighResImage(c);
        doc.addImage(imgData, 'PNG', imgX, imgY, imgW, imgH);
      }
      doc.save(pdfFileName);
      showToast('PDF downloaded: ' + pdfFileName, 'success');
    }
    document.getElementById('analysis-download-pdf-btn')?.addEventListener('click', downloadChartsPdf);

    // Function to load file history (globally defined)
