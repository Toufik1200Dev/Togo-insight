      fileInput.addEventListener('change', async (e) => {
        if (!e.target.files.length) {
          // If no file is selected, just return without showing any animation
          return;
        }

        const file = e.target.files[0];
        // Check if file is actually a CSV
        if (!file.name.toLowerCase().endsWith('.csv')) {
          showToast('Please select a CSV file.', 'error');
          return;
        }
        
        // Update upload button to show "Uploading..." state
        uploadButtonText.textContent = "Uploading...";
        uploadButtonIcon.className = "fas fa-spinner fa-spin";
        uploadButton.classList.add('uploading');
        
        // Show loading spinner during upload
        loadingSpinner.classList.remove('hidden');
        processingStatus.classList.add('hidden'); // Hide processing status initially
        downloadButtons.classList.add('hidden'); // Hide download buttons initially
        
        // Reset download buttons
        downloadLillybelleBtn.disabled = true;
        downloadArcepBtn.disabled = true;
        currentFileName.textContent = `Processing: ${file.name}`;
        
        // Create form data and send the file to the server
        const formData = new FormData();
        formData.append('file', file);

        try {
          const response = await fetch('/upload', {
            method: 'POST',
            body: formData
          });

          const data = await response.json();
          
          if (response.ok && data.success) {
            // Store the file reference for polling
            currentFileReference = data.fileReference;
            currentFileName.textContent = `Snowflake processing: ${data.originalFileName} (Ref: ${data.fileReference})`;
            
            // Show toast notification
            showToast('File uploaded to Snowflake for processing. Checking for output files...', 'info');
            
            // Start polling for files in Azure OUTPUT folder
            pollFileProcessing();
            
            // Refresh file history immediately
            loadFileHistory();
          } else {
            // Hide animations on error
            loadingSpinner.classList.add('hidden');
            processingStatus.classList.add('hidden');
            downloadButtons.classList.add('hidden');
            showToast('Upload failed: ' + data.message, 'error');
